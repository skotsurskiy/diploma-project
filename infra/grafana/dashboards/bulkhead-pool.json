{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "active = з'єднання в роботі; pending = потоки, що ЧЕКАЮТЬ вільного з'єднання (>0 = пул вичерпується). max = 10.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2, "showPoints": "never" },
          "unit": "short"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "pending (очікують з'єднання)" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] },
          { "matcher": { "id": "byName", "options": "active (в роботі)" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } } ] },
          { "matcher": { "id": "byName", "options": "max (пул = 10)" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "gray" } }, { "id": "custom.lineStyle", "value": { "dash": [8, 8], "fill": "dash" } } ] }
        ]
      },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["max"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "hikaricp_connections_active{pool=\"HikariPool-1\"}", "legendFormat": "active (в роботі)", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "hikaricp_connections_pending{pool=\"HikariPool-1\"}", "legendFormat": "pending (очікують з'єднання)", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "hikaricp_connections_max{pool=\"HikariPool-1\"}", "legendFormat": "max (пул = 10)", "refId": "C" }
      ],
      "title": "① HikariCP — стан пулу з'єднань",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Вільні дозволи семафора Bulkhead (з 8). 0 = семафор насичений, надлишок отримує fail-fast 503.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "green" },
          "custom": { "drawStyle": "line", "lineInterpolation": "stepAfter", "fillOpacity": 20, "lineWidth": 2, "showPoints": "never" },
          "unit": "short", "min": 0, "max": 8
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 9 },
      "id": 2,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "resilience4j_bulkhead_available_concurrent_calls{name=\"db\"}", "legendFormat": "вільних дозволів (з 8)", "refId": "A" }
      ],
      "title": "② Bulkhead — вільні дозволи семафора",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Максимальний час очікування вільного з'єднання. Зростання = пул вичерпано (без bulkhead).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 15 },
      "id": 3,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["max"] }, "tooltip": { "mode": "single" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "hikaricp_connections_acquire_seconds_max{pool=\"HikariPool-1\"}", "legendFormat": "час очікування з'єднання (max)", "refId": "A" }
      ],
      "title": "③ Час отримання з'єднання з пулу (с)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 25, "lineWidth": 2, "showPoints": "never" },
          "unit": "reqps"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "успішно (201)" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } } ] },
          { "matcher": { "id": "byName", "options": "відмова 5xx (503/500)" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] }
        ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 22 },
      "id": 4,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(k6_outcome_success_201_total[15s]))", "legendFormat": "успішно (201)", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(k6_outcome_rejected_5xx_total[15s]))", "legendFormat": "відмова 5xx (503/500)", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "k6_http_req_duration_p95", "legendFormat": "p95 латентність (с)", "refId": "C" }
      ],
      "title": "④ Потік за типом результату (req/s) + p95",
      "type": "timeseries"
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["k6", "resilience", "bulkhead"],
  "templating": { "list": [] },
  "time": { "from": "now-5m", "to": "now" },
