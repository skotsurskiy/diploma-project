          "min": 0, "max": 1
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "OPEN (fail-fast)" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] },
          { "matcher": { "id": "byName", "options": "HALF_OPEN (проба)" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } } ] },
          { "matcher": { "id": "byName", "options": "CLOSED (норма)" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } } ] }
        ]
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 5 },
      "id": 11,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "resilience4j_circuitbreaker_state{name=\"payment\",state=\"closed\"}", "legendFormat": "CLOSED (норма)", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "resilience4j_circuitbreaker_state{name=\"payment\",state=\"open\"}", "legendFormat": "OPEN (fail-fast)", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "resilience4j_circuitbreaker_state{name=\"payment\",state=\"half_open\"}", "legendFormat": "HALF_OPEN (проба)", "refId": "C" }
      ],
      "title": "② Стан Circuit Breaker (1 = активний стан)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Потік запитів за типом результату. Спрацювання CB: 'успішно 201' падає, '503 fail-fast' росте.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 25, "lineWidth": 2, "showPoints": "never" },
          "unit": "reqps"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "успішно (201)" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } } ] },
          { "matcher": { "id": "byName", "options": "503 fail-fast (CB)" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } } ] },
          { "matcher": { "id": "byName", "options": "conn timeout (сервер захлинувся)" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] }
        ]
      },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 11 },
