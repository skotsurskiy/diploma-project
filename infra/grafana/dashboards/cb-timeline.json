      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(k6_outcome_success_201_total[15s]))", "legendFormat": "успішно (201)", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(k6_outcome_rejected_5xx_total[15s]))", "legendFormat": "503 fail-fast (CB)", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(k6_outcome_conn_timeout_total[15s]))", "legendFormat": "conn timeout (сервер захлинувся)", "refId": "C" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(k6_http_reqs_total[15s]))", "legendFormat": "усього оброблено", "refId": "D" }
      ],
      "title": "③ Пропускна здатність за типом результату (req/s)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
